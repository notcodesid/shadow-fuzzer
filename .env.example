# --- RPC / Snapshot ---
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
SOLANA_RPC_URL=${HELIUS_RPC_URL}

# --- MagicBlock Private Ephemeral Rollup (primary sandbox) ---
# Provisioning endpoint for a private ER. The agent spins one up per fuzz run
# and tears it down at the end so nothing leaks to the public mempool.
MAGICBLOCK_PROVIDER_URL=
MAGICBLOCK_API_KEY=
MAGICBLOCK_VALIDATOR_REGION=us-east

# --- Surfpool fallback ---
# Only used when SHADOW_SANDBOX=surfpool or MagicBlock provisioning fails.
SURFPOOL_RPC_URL=http://127.0.0.1:8899

# --- Agent brain ---
# SendAI / Solana Agent Kit uses an LLM under the hood. ANTHROPIC_API_KEY is
# the default; OPENAI_API_KEY is accepted as fallback.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SHADOW_AGENT_MODEL=claude-opus-4-7

# --- Fuzzer config ---
SHADOW_SANDBOX=magicblock          # magicblock | surfpool
SHADOW_FUZZ_BUDGET_TX=2000         # max txs per fuzz run
SHADOW_FUZZ_PARALLELISM=8
SHADOW_REPORT_DIR=./reports

# --- Fuzz wallet (NEVER reuse a real key) ---
# Path to the throwaway keypair the agent uses inside the ER.
FUZZ_PAYER_KEYPAIR=./.shadow-fuzzer/fuzz-payer.json
