# --- RPC ---
# Anything web3.js-compatible. Defaults work; only override if you have
# a private RPC (Helius, QuickNode, etc.) for higher rate limits.
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- MagicBlock Private Ephemeral Rollup (--sandbox magicblock only) ---
# The Magic Router HTTP endpoint. Tx routing decides which ER validator
# handles each tx based on the delegation status of the touched accounts.
# Public devnet router below; no API key required.
MAGICBLOCK_ROUTER_URL=https://devnet.magicblock.app

# Optional. Path to a Solana keypair the agent uses to acquire a
# Private-ER auth token via getAuthToken(). Without this the agent runs
# against the public ER (no per-session access control).
MAGICBLOCK_AUTH_KEYPAIR=

# --- Surfpool fallback ---
# Only used when --sandbox=surfpool or MagicBlock provisioning fails.
SURFPOOL_RPC_URL=http://127.0.0.1:8899

# --- Fuzzer config ---
SHADOW_SANDBOX=magicblock          # magicblock | surfpool
SHADOW_FUZZ_BUDGET_TX=2000         # max txs per fuzz run
SHADOW_REPORT_DIR=./reports

# --- Fuzz wallet (NEVER reuse a real key) ---
# Path to the keypair the agent uses as fee payer. The default Solana
# CLI keypair works fine for devnet; do not point this at a mainnet key.
FUZZ_PAYER_KEYPAIR=
