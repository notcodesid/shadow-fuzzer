{
  "name": "shadow-fuzzer",
  "version": "0.1.0",
  "description": "AI security agent that fuzzes Solana programs in a Private Ephemeral Rollup sandbox — find bugs without leaking exploits to MEV bots.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "shadow-fuzz": "bin/shadow-fuzz.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "assets",
    "README.md"
  ],
  "keywords": [
    "solana",
    "security",
    "fuzz",
    "ai-agent",
    "magicblock",
    "ephemeral-rollups",
    "anchor"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.2.11",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "kleur": "^4.1.5",
    "ora": "^8.1.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@shadow-fuzzer/agent": "workspace:*",
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
