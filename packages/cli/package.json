{
  "name": "shadow-fuzzer",
  "version": "0.1.0",
  "description": "AI security agent that fuzzes Solana programs in a Private Ephemeral Rollup sandbox — find bugs without leaking exploits to MEV bots.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "shadow-fuzz": "./bin/shadow-fuzz.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin",
    "assets",
    "README.md"
  ],
  "keywords": [
    "solana",
    "security",
    "fuzz",
    "ai-agent",
    "magicblock",
    "ephemeral-rollups",
    "anchor"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@shadow-fuzzer/agent": "workspace:*",
    "@solana/web3.js": "^1.98.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "kleur": "^4.1.5",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
